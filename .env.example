# Chỉ cần cổng 8080 trên máy — toàn bộ web + API + Socket.io qua nginx (Docker)
CLIENT_PORT=8080

# CORS cho server (khi truy cập qua http://localhost:8080)
CORS_ORIGIN=http://localhost:8080,http://127.0.0.1:8080

# Vercel build (packages/client) — URL máy chủ Render/Railway (không slash cuối)
# VITE_SOCKET_URL=https://bto-server.onrender.com
